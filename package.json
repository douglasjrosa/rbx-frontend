{
  "name": "ribermax-frontend",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "npx next dev --turbopack -H 0.0.0.0 -p 3000",
    "dev:clean": "npm run clean && npm run dev",
    "build": "npm run validate-seo && npx next build",
    "start": "npx next start",
    "lint": "npx next lint",
    "validate-seo": "node scripts/validate-seo-images.mjs",
    "generate-seo-images": "node scripts/generate-seo-page-images.mjs",
    "download-images": "node scripts/download-images.mjs"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "classnames": "^2.5.1",
    "next": "^16.2.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/sanitize-html": "^2.16.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ]
}
